# Auto-detect text files and normalize line endings
* text=auto

# Python files always use LF
*.py text eol=lf

# Config files always use LF
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.json text eol=lf

# Windows batch files use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf